{
    "manifest_version": 3,
    "name": "FreeSaveVideo Downloader",
    "version": "0.1.1",
    "description": "Detect media on the current page and open supported public links in FreeSaveVideo.",
    "action": {
        "default_popup": "popup/index.html",
        "default_title": "FreeSaveVideo"
    },
    "background": {
        "service_worker": "assets/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.tiktok.com/*",
                "*://*.instagram.com/*",
                "*://*.douyin.com/*",
                "*://*.iesdouyin.com/*",
                "*://*.bilibili.com/*",
                "*://*.bilibili.tv/*",
                "*://*.b23.tv/*",
                "*://learn.deeplearning.ai/*",
                "*://freesavevideo.online/*",
                "*://*.freesavevideo.online/*",
                "http://localhost/*",
                "http://127.0.0.1/*"
            ],
            "js": ["assets/content.js"],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": [
        "*://*.instagram.com/*",
        "*://*.fbcdn.net/*",
        "*://*.cdninstagram.com/*",
        "*://*.tiktok.com/*",
        "*://*.tiktokcdn.com/*",
        "*://*.tiktokv.com/*",
        "*://*.tokcdn.com/*",
        "*://*.byteoversea.com/*",
        "*://*.ibytedtos.com/*",
        "*://*.muscdn.com/*",
        "*://*.akamaized.net/*",
        "*://*.douyin.com/*",
        "*://*.iesdouyin.com/*",
        "*://*.douyinvod.com/*",
        "*://*.bytevod.com/*",
        "*://*.zjcdn.com/*",
        "*://*.bilibili.com/*",
        "*://*.bilibili.tv/*",
        "*://*.b23.tv/*",
        "*://*.bilivideo.com/*",
        "*://*.hdslb.com/*",
        "*://learn.deeplearning.ai/*",
        "*://*.cloudfront.net/*"
    ],
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "permissions": ["activeTab", "downloads", "scripting", "storage", "tabs", "webRequest"]
}
