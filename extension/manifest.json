{
    "manifest_version": 3,
    "name": "FreeSaveVideo Downloader",
    "version": "0.1.0",
    "description": "Detect media on the current page and open supported public links in FreeSaveVideo.",
    "action": {
        "default_popup": "popup/index.html",
        "default_title": "FreeSaveVideo"
    },
    "background": {
        "service_worker": "assets/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["*://*.tiktok.com/*", "*://*.instagram.com/*"],
            "js": ["assets/content.js"],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": [
        "*://*.instagram.com/*",
        "*://*.fbcdn.net/*",
        "*://*.cdninstagram.com/*",
        "*://*.tiktok.com/*",
        "*://*.tiktokcdn.com/*",
        "*://*.byteoversea.com/*",
        "*://*.muscdn.com/*",
        "*://*.akamaized.net/*"
    ],
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "permissions": ["activeTab", "downloads", "scripting", "storage", "tabs", "webRequest"]
}
